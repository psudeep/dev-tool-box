{
  "name": "dev-toolbox",
  "version": "1.0.0",
  "description": "A mini all-in-one utility for developers",
  "main": "src/main/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start-renderer\" \"wait-on http://localhost:3004 && electron .\"",
    "start-renderer": "PORT=3004 react-scripts start",
    "build": "react-scripts build",
    "build-electron": "npm run build && electron-builder",
    "build-all": "npm run build && electron-builder --mac --win --linux",
    "test": "react-scripts test",
    "test:e2e": "jest --config=jest.e2e.config.js",
    "eject": "react-scripts eject",
    "dist": "npm run build && electron-builder --publish=never",
    "publish": "npm run build && electron-builder --publish=always",
    "pack": "electron-builder --dir",
    "prepack": "npm run build"
  },
  "build": {
    "appId": "com.devtools.toolbox",
    "productName": "Dev Toolbox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "src/main/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "keywords": [
    "developer-tools",
    "json-formatter",
    "base64-decoder",
    "jwt-decoder",
    "curl-converter",
    "regex-tester",
    "color-picker",
    "markdown-preview",
    "api-tester"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-html": "^6.4.6",
    "@codemirror/lang-javascript": "^6.2.1",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@monaco-editor/react": "^4.6.0",
    "@uiw/react-codemirror": "^4.21.13",
    "axios": "^1.5.0",
    "codemirror": "^6.0.1",
    "dompurify": "^3.0.5",
    "electron": "^27.0.0",
    "js-beautify": "^1.14.9",
    "jsonlint": "^1.6.3",
    "jwt-decode": "^3.1.2",
    "marked": "^9.1.2",
    "react": "^18.2.0",
    "react-color": "^2.19.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "jest": "^29.5.0",
    "react-scripts": "5.0.1",
    "wait-on": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
